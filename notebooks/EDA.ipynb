import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.preprocessing import StandardScaler

— Veri Setini Yükleme
df = pd.read_csv("../data/training.csv")
df.head()

— Boyut, Özet Bilgi
print("Veri Boyutu:", df.shape)
df.info()

— İstatistiksel Özet
df.describe()

— Eksik Değer Analizi
missing = df.replace(-999.0, np.nan).isnull().sum()
missing[missing > 0]

— Etiket Dağılımı
plt.figure(figsize=(5,4))
df['Label'].value_counts().plot(kind='bar')
plt.title("Etiket Dağılımı")
plt.xlabel("Etiket")
plt.ylabel("Frekans")
plt.show()

— Basit Korelasyon Analizi
corr = df.corr(numeric_only=True)
plt.figure(figsize=(10, 8))
plt.imshow(corr, cmap="viridis", aspect="auto")
plt.colorbar()
plt.title("Korelasyon Matrisi (Özellikler)")
plt.show()
Not: Higgs verisi çok özellik içerdiği için görsel yoğun olacaktır ama araştırma amaçlıdır.

